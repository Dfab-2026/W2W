# Public browser configuration. These values are designed to be used by the frontend.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
# Optional newer Supabase key name supported by this project:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Server-only Supabase key. Add this only in .env.local or Vercel Environment Variables.
# Never prefix a secret key with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_xxxxx
# Legacy alternative supported by this project:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

RESEND_API_KEY=your_resend_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_public_key
GOOGLE_MAPS_API_KEY=your_google_maps_server_key
TWO_FACTOR_API_KEY=your_2factor_key
TWO_FACTOR_TEMPLATE_NAME=WORK2WISHOTP
ALLOW_DEV_OTP=false
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_value_not_url
NEXT_PUBLIC_APP_URL=https://app.work2wish.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:support@work2wish.com
